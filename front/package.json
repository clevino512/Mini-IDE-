{
  "name": "mini-ide",
  "version": "1.0.0",
  "description": "A minimal desktop code editor IDE",
  "main": "dist/main/main.js",
  "homepage": "./",
  "scripts": {
    "dev": "npm run build:electron && concurrently \"npm run vite:dev\" \"wait-on http://localhost:5173 && npm run electron:dev\"",
    "vite:dev": "vite --port 5173",
    "electron:dev": "cross-env NODE_ENV=development electron dist/main/main.js",
    "electron:watch": "tsc --project tsconfig.electron.json --watch",
    "build": "npm run build:vite && npm run build:electron",
    "build:vite": "vite build",
    "build:electron": "tsc --project tsconfig.electron.json",
    "pack": "npm run build && electron-builder"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "mongoose": "^8.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^8.0.0",
    "cross-env": "^10.1.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.2.1",
    "terser": "^5.46.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "wait-on": "^7.0.0"
  }
}
