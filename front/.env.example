# MongoDB Configuration
# Default: mongodb://localhost:27017/mini-ide
# Change in src/main/main.ts mongoUri constant if needed
MONGODB_URI=mongodb://localhost:27017/mini-ide

# Vite Configuration
# Dev server port (default: 5173)
VITE_PORT=5173

# Electron Configuration
# Set to false to disable dev tools in production
VITE_DEV_TOOLS=true
